# =====================================
# Toolbox Everything - Configuration
# =====================================

# Version de l'application
APP_VERSION=1.3.0

# =====================================
# Docker Compose — mode de déploiement
# =====================================
# Laisser vide ou non défini pour BUILD LOCAL :
#   docker compose up -d --build
# Définir pour utiliser l'image Docker Hub :
#   TOOLBOX_IMAGE=doalo/toolbox-everything:1.3.0
#TOOLBOX_IMAGE=

# Ports exposés (utiles si les ports par défaut sont occupés)
#TOOLBOX_PORT=8000
#STIRLING_PORT=8080

# =====================================
# Stirling PDF (outils PDF intégrés)
# =====================================
# URL interne (container-to-container) pour le healthcheck Flask
STIRLING_PDF_URL=http://stirling-pdf:8080
# URL publique exposée dans l'iframe côté navigateur
STIRLING_PDF_PUBLIC_URL=http://localhost:8080

# Configuration Flask
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-change-this-in-production

# Configuration serveur
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Limites de fichiers (en bytes)
MAX_CONTENT_LENGTH=524288000  # 500MB
MAX_FILE_SIZE_MB=500

# Dossiers de stockage
UPLOAD_FOLDER=uploads
DOWNLOAD_FOLDER=downloads
TEMP_FOLDER=temp
LOGS_FOLDER=logs

# Configuration YouTube Downloader
YOUTUBE_QUALITY_DEFAULT=best
YOUTUBE_FORMAT_DEFAULT=mp4
YOUTUBE_MAX_DURATION=3600  # 1 heure en secondes

# Configuration convertisseur média
MEDIA_QUALITY_DEFAULT=high
MEDIA_COMPRESSION_DEFAULT=medium
SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,webp,gif,bmp
SUPPORTED_VIDEO_FORMATS=mp4,avi,mkv,mov,wmv,flv
SUPPORTED_AUDIO_FORMATS=mp3,wav,aac,ogg,flac

# Configuration sécurité
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
CSRF_ENABLED=true
SECURE_HEADERS_ENABLED=true

# Configuration cache
CACHE_ENABLED=true
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300  # 5 minutes

# Configuration logging
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=false

# Configuration compression
COMPRESS_MIMETYPES=text/html,text/css,text/xml,application/json,application/javascript
COMPRESS_LEVEL=6
COMPRESS_MIN_SIZE=500

# Configuration développement
DEV_RELOAD=true
DEV_DEBUGGER=true
DEV_PROFILER=false

# Configuration externe (optionnel)
# API_TIMEOUT=30
# USER_AGENT=Toolbox Everything/${APP_VERSION}
# PROXY_URL=
# PROXY_AUTH=

# Configuration monitoring (production)
# SENTRY_DSN=
# METRICS_ENABLED=false
# HEALTH_CHECK_ENABLED=true 