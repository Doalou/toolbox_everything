# =====================================================
# Toolbox Everything — .env.example
#
# Seules les variables réellement lues par le code sont listées.
# Copier ce fichier en `.env` puis ajuster. Les valeurs commentées
# montrent les défauts appliqués si la variable n'est pas définie.
# =====================================================

# --- Version ---------------------------------------------------------
APP_VERSION=1.3.1

# --- Docker Compose --------------------------------------------------
# Laisser vide pour BUILD LOCAL (`docker compose up -d --build`).
# Définir pour utiliser une image pré-construite :
#   TOOLBOX_IMAGE=ghcr.io/doalou/toolbox_everything:1.3.1
#TOOLBOX_IMAGE=

# Ports exposés côté hôte (défauts : 8000 Toolbox, 8080 Stirling, 8081 LibreSpeed)
#TOOLBOX_PORT=8000
#STIRLING_PORT=8080
#LIBRESPEED_PORT=8081

# --- Flask -----------------------------------------------------------
SECRET_KEY=change-me-en-production-ou-laisser-vide-pour-autogenerer
FLASK_ENV=production
HOST=0.0.0.0
PORT=8000

# --- Stirling PDF ----------------------------------------------------
# URL interne (container-to-container) pour le healthcheck
STIRLING_PDF_URL=http://stirling-pdf:8080
# URL publique exposée dans l'iframe côté navigateur
STIRLING_PDF_PUBLIC_URL=http://localhost:8080

# --- LibreSpeed ------------------------------------------------------
# URL interne (container-to-container) pour le healthcheck
LIBRESPEED_URL=http://librespeed
# URL publique exposée dans l'iframe côté navigateur
LIBRESPEED_PUBLIC_URL=http://localhost:8081

# --- Rate limiter (Flask-Limiter) ------------------------------------
# Storage des compteurs. `redis://...` en prod (partagé entre workers
# gunicorn), `memory://` en dev (par worker, éphémère).
RATELIMIT_STORAGE_URI=redis://redis:6379/0

# --- Uploads / conversion --------------------------------------------
# Taille max d'une requête (bytes). 512 MB par défaut.
#MAX_CONTENT_LENGTH=536870912

# --- FFmpeg ----------------------------------------------------------
# Chemin explicite vers le binaire ffmpeg. Par défaut, auto-détecté
# via PATH, puis `/usr/bin/ffmpeg`, `/usr/local/bin/ffmpeg`, `bin/ffmpeg(.exe)`.
#FFMPEG_PATH=
